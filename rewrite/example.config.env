# Database Configuration
DB_DRIVER=sqlite+aiosqlite  # Use sqlite+aiosqlite for dev, postgresql+asyncpg for prod
DB_HOST=localhost
DB_PORT=5432  # Only used for PostgreSQL
DB_NAME=userdb
DB_USER=postgres  # Only used for PostgreSQL
DB_PASSWORD=password  # Only used for PostgreSQL

# SQLite specific (dev)
SQLITE_DB_PATH=db.sqlite3

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Application settings
DEBUG=true
