# Database
DATABASE_URL=sqlite+aiosqlite:///./testdb.sqlite

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
DEBUG=true

# Security
SECRET_KEY=development_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
ENABLE_RATE_LIMITING=false
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=* 